# Local development defaults. For Hetzner, copy `.env.hetzner.example` to `.env`
# and replace every placeholder before running `docker compose up -d --build`.

DEPLOYMENT_MODE="local"

POSTGRES_USER="dromaios"
POSTGRES_PASSWORD="dromaios"
POSTGRES_DB="dromaios_cockpit"
POSTGRES_BIND_IP="127.0.0.1"
POSTGRES_PORT="5432"

DATABASE_URL="postgresql://dromaios:dromaios@localhost:5432/dromaios_cockpit?schema=public"

APP_BIND_IP="127.0.0.1"
APP_PORT="3300"
COCKPIT_BIND_IP="127.0.0.1"
COCKPIT_HTTP_PORT="8080"

SESSION_SECRET="replace-with-at-least-24-random-characters"
ADMIN_EMAIL="admin@dromaios.local"
ADMIN_PASSWORD="change-me-now"
ADMIN_NAME="Dromaios Admin"

OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma3:1b"
COOKIE_SECURE="false"
