{
  "name": "dromaios-company-cockpit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-next-dev.mjs",
    "codex:run": "node scripts/start-next-dev.mjs --hostname 127.0.0.1 --port 3003",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:run-flow": "node --test scripts/*.test.mjs",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:roadmap": "tsx prisma/seed-roadmap.ts",
    "check:publish": "tsx scripts/check-publish.ts",
    "deploy:preflight": "node scripts/deployment-preflight.mjs",
    "smoke:compose": "docker compose config"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.468.0",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.12.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.4.22",
    "eslint": "9.39.1",
    "eslint-config-next": "15.5.18",
    "jsdom": "27.2.0",
    "postcss": "8.5.15",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
