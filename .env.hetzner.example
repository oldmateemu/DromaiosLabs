# Copy to `.env` on the Hetzner server and replace every placeholder.
# Keep passwords URL-safe: letters, numbers, dot, underscore, tilde, hyphen.

DEPLOYMENT_MODE="production"

POSTGRES_USER="dromaios"
POSTGRES_PASSWORD="replace-with-url-safe-db-password-32"
POSTGRES_DB="dromaios_cockpit"
POSTGRES_BIND_IP="127.0.0.1"
POSTGRES_PORT="5432"

APP_BIND_IP="127.0.0.1"
APP_PORT="3300"

# For SSH-tunnel-only access, keep 127.0.0.1.
# For VPN access, set this to the server's Tailscale or WireGuard IPv4 address.
COCKPIT_BIND_IP="127.0.0.1"
COCKPIT_HTTP_PORT="8080"

SESSION_SECRET="replace-with-32-plus-random-url-safe-characters"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="replace-with-16-plus-random-characters"
ADMIN_NAME="Dromaios Admin"

# If Ollama runs on the Hetzner host, keep host.docker.internal.
# If Ollama runs elsewhere on the VPN, set the VPN URL instead.
OLLAMA_BASE_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="gemma3:1b"

# Document intake pathway storage inside the container (backed by the
# intake_data volume, or a host bind in docker-compose.yml). Scanners and the
# email sync drop files into <INTAKE_DIR>/inbox/scan and <INTAKE_DIR>/inbox/email.
INTAKE_DIR="/data/intake"

# Keep false for local/VPN HTTP. Set true only behind HTTPS.
COOKIE_SECURE="false"
